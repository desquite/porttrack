# =========================================================================
# PORTTRACK — Variables d'environnement (apps/web)
# Copier ce fichier en .env.local puis remplir les valeurs.
# .env.local est ignoré par git — ne JAMAIS le committer.
# =========================================================================

# -------------------------------------------------------------------------
# Supabase — REQUIS pour démarrer
# Récupérer depuis : Supabase Dashboard > Project Settings > API
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Clé service_role : ne JAMAIS exposer côté client.
# Utilisée uniquement dans les Server Actions / Route Handlers pour
# les opérations d'administration (création de tenant, seed initial…).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# -------------------------------------------------------------------------
# WhatsApp Business API (Phase 2 — bot documents et alertes)
# Voir cahier §7.5 et §13.6. Provider recommandé : Meta WhatsApp Business
# ou Twilio. Laisser vide en Phase 1.
# -------------------------------------------------------------------------
WHATSAPP_PROVIDER=meta            # meta | twilio
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# -------------------------------------------------------------------------
# Email transactionnel (alertes BADT, alertes documents)
# Provider recommandé : SendGrid ou Mailgun. Laisser vide en Phase 1.
# -------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid           # sendgrid | mailgun
EMAIL_API_KEY=
EMAIL_FROM=alerts@porttrack.ci
EMAIL_FROM_NAME=PORTTRACK Alerts

# -------------------------------------------------------------------------
# SMS (OTP de connexion adapté au terrain ivoirien)
# Provider : Twilio ou Orange CI. Optionnel si OTP par email.
# -------------------------------------------------------------------------
SMS_PROVIDER=twilio               # twilio | orange-ci
SMS_API_KEY=
SMS_FROM=PORTTRACK

# -------------------------------------------------------------------------
# Stockage fichiers (EIR, justificatifs, scans documents)
# Par défaut : Supabase Storage (déjà couvert par les clés Supabase ci-dessus).
# Pour utiliser un bucket S3 externe, renseigner ci-dessous.
# -------------------------------------------------------------------------
STORAGE_PROVIDER=supabase         # supabase | s3
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# -------------------------------------------------------------------------
# Application
# -------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PORTTRACK

# Fuseau horaire pour les jobs cron (alertes BADT à 6h00 — cahier §13.2)
SCHEDULER_TIMEZONE=Africa/Abidjan
